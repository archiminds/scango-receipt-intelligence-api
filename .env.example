# Copy this file to `.env` and fill in real values before running locally.

# AWS Configuration
AWS_REGION=<YOUR_AWS_REGION>
AWS_PROFILE=<OPTIONAL_AWS_PROFILE>

# Bedrock Configuration
BEDROCK_MODEL_ID=<YOUR_BEDROCK_MODEL_ID>

# DynamoDB Configuration
DYNAMODB_TABLE_NAME=<YOUR_DYNAMODB_TABLE>

# Optional S3 bucket for artifacts/synthetic data
S3_BUCKET_NAME=<OPTIONAL_S3_BUCKET>

# Lambda/Application Settings
LOG_LEVEL=INFO
